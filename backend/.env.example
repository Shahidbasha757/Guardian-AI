APP_NAME="Guardian AI Backend"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
CORS_ORIGINS="*"

# Configure one of these for Firestore/Firebase Authentication.
FIREBASE_PROJECT_ID=""
FIREBASE_CREDENTIALS_PATH=""
FIREBASE_CREDENTIALS_JSON=""
FIREBASE_WEB_API_KEY=""
AI_SERVICE_URL="http://127.0.0.1:3000"

# Keep true for Swagger demos without Firebase credentials.
ENABLE_LOCAL_AUTH_FALLBACK=true
DEFAULT_MONITORING_ACTIVE=true

